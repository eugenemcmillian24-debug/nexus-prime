# ============================================================
# NEXUS PRIME — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.
# ============================================================

# --- Supabase (Public — safe to expose in browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# --- Supabase (Secret — server-side only) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- AI / LLM Keys ---
GROQ_API_KEY=your_groq_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
GOOGLE_AI_KEY=your_google_ai_key          # Required for Gemini 1.5 Pro vision

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...         # $9/mo — 100 credits
STRIPE_PRO_PRICE_ID=price_...             # $29/mo — 500 credits
STRIPE_ENTERPRISE_PRICE_ID=price_...      # $99/mo — 2000 credits

# --- Vercel Deployment (One-Click Deploy feature) ---
VERCEL_TOKEN=your_vercel_token
VERCEL_TEAM_ID=your_team_id               # Optional — leave blank for personal accounts

# --- App ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000  # Change to your production URL on deploy
