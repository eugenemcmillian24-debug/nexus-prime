# ============================================
# Nexus Prime — Environment Variables
# ============================================
# Copy this to .env.local and fill in your values.
# All vars marked [REQUIRED] must be set for the app to function.

# ─── Supabase ────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=           # [REQUIRED] Supabase project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # [REQUIRED] Supabase anon/public key
SUPABASE_URL=                       # [REQUIRED] Same as NEXT_PUBLIC_SUPABASE_URL (used server-side)
SUPABASE_SERVICE_ROLE_KEY=          # [REQUIRED] Supabase service role key (server-side only)

# ─── Stripe ──────────────────────────────────
STRIPE_SECRET_KEY=                  # [REQUIRED] Stripe secret key (sk_test_... or sk_live_...)
STRIPE_WEBHOOK_SECRET=              # [REQUIRED] Stripe webhook signing secret (whsec_...)

# Subscription price IDs (create in Stripe Dashboard)
STRIPE_STARTER_PRICE_ID=            # [REQUIRED] Starter plan recurring price ID
STRIPE_PRO_PRICE_ID=                # [REQUIRED] PRO plan recurring price ID
STRIPE_ENTERPRISE_PRICE_ID=         # [REQUIRED] Enterprise plan recurring price ID

# Top-up pack price IDs (one-time payments)
STRIPE_TOPUP_50_PRICE_ID=           # [REQUIRED] 50 credits top-up price ID
STRIPE_TOPUP_250_PRICE_ID=          # [REQUIRED] 250 credits top-up price ID
STRIPE_TOPUP_1000_PRICE_ID=         # [REQUIRED] 1000 credits top-up price ID

# ─── AI Providers ────────────────────────────
GROQ_API_KEY=                       # [REQUIRED] Groq API key (for transcription + fast LLM)
OPENROUTER_API_KEY=                 # [REQUIRED] OpenRouter API key (multi-model routing)
GOOGLE_AI_KEY=                      # [REQUIRED] Google AI / Gemini API key

# ─── App Config ──────────────────────────────
NEXT_PUBLIC_BASE_URL=               # [REQUIRED] Your app URL (e.g., https://nexus-prime-woad.vercel.app)
NEXUS_UNTHROTTLED_BUILD=            # [OPTIONAL] Set to "true" to disable build rate limiting

# ─── Vercel (for admin panel features) ───────
VERCEL_TOKEN=                       # [OPTIONAL] Vercel API token (admin: env sync & logs)
VERCEL_PROJECT_ID=                  # [OPTIONAL] Vercel project ID (admin: deployment management)
VERCEL_TEAM_ID=                     # [OPTIONAL] Vercel team ID (if using team scope)

# ─── Export Integrations (optional) ──────────
GITHUB_TOKEN=                       # [OPTIONAL] GitHub PAT (for GitHub export)
NETLIFY_PERSONAL_TOKEN=             # [OPTIONAL] Netlify token (for Netlify export)
CLOUDFLARE_API_TOKEN=               # [OPTIONAL] Cloudflare API token (for CF Pages export)
CLOUDFLARE_ACCOUNT_ID=              # [OPTIONAL] Cloudflare account ID (for CF Pages export)
