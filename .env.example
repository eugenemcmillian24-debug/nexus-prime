# --- NEXUS PRIME: Environment Variables Template ---

# 1. Supabase (Core Backend)
# Get these from Settings -> API in your Supabase Dashboard
NEXT_PUBLIC_SUPABASE_URL=your_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# --- ADMIN/MANAGEMENT KEY (PROVIDED) ---
SUPABASE_MANAGEMENT_API_KEY=your_supabase_management_key

# 2. AI & LLM Orchestration
# Required for Code Generation, Security Audits, and Reasoning
GROQ_API_KEY=your_groq_key
OPENROUTER_API_KEY=your_openrouter_key
GOOGLE_AI_KEY=your_google_ai_key # For Vision features (Gemini 2.0 Flash)

# 3. Deployment & DevOps (Vercel)
# Required for AI Self-Healing Deploys and Vercel Integration
# --- VERCEL TOKEN (PROVIDED) ---
VERCEL_TOKEN=your_vercel_token
VERCEL_TEAM_ID=your_team_id # Optional: Only if deploying to a team account

# 4. Cloud Export Engine (Feature #8)
# Required for Multi-Platform One-Click Deployment
GITHUB_TOKEN=your_github_token # Needs 'repo' scope
NETLIFY_PERSONAL_TOKEN=your_netlify_token
CLOUDFLARE_API_TOKEN=your_cloudflare_pages_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# 5. Payments & Billing
# Required for Subscription tiers (Stripe)
# --- STRIPE CREDENTIALS (PROVIDED) ---
STRIPE_ACCOUNT_ID=your_stripe_account_id
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- SUBSCRIPTION PRICE IDS ---
STRIPE_STARTER_PRICE_ID=price_starter_...
STRIPE_PRO_PRICE_ID=price_pro_...
STRIPE_ENTERPRISE_PRICE_ID=price_ent_...

# --- TOP-UP PRICE IDS ---
STRIPE_TOPUP_50_PRICE_ID=price_topup_50_...
STRIPE_TOPUP_250_PRICE_ID=price_topup_250_...
STRIPE_TOPUP_1000_PRICE_ID=price_topup_1000_...

# --- ADD-ON PRICE IDS ---
STRIPE_ADDON_DOMAIN_PRICE_ID=price_addon_dom_...
STRIPE_ADDON_PRIORITY_PRICE_ID=price_addon_prio_...

# 6. Auth
# Used for secure session management
NEXTAUTH_SECRET=your_random_secret_string
NEXTAUTH_URL=http://localhost:3000
